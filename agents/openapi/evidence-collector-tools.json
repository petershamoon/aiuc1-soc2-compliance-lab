{
  "openapi": "3.0.0",
  "info": {
    "title": "AIUC-1 Evidence Collector Tools",
    "description": "Azure Functions providing evidence collection and validation capabilities for the evidence-collector agent.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aiuc1-soc2-tools.azurewebsites.net/api",
      "description": "AIUC-1 Azure Function App"
    }
  ],
  "paths": {
    "/scan_cc_criteria": {
      "post": {
        "operationId": "scan_cc_criteria",
        "summary": "Scan Azure resources against a SOC 2 Common Criteria control",
        "description": "Scan Azure resources against a specific SOC 2 Common Criteria (CC) control. Returns a structured compliance assessment with pass/fail findings, resource details, and evidence references. Supported categories: CC6, CC7, CC8, CC9.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cc_category"],
                "properties": {
                  "cc_category": {
                    "type": "string",
                    "description": "The SOC 2 Common Criteria category to scan.",
                    "enum": ["CC6", "CC7", "CC8", "CC9"]
                  },
                  "resource_group": {
                    "type": "string",
                    "description": "Optional. Azure resource group to scope the scan."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compliance scan results",
            "content": {
              "application/json": {
                "schema": {"type": "object"}
              }
            }
          }
        }
      }
    },
    "/evidence_validator": {
      "post": {
        "operationId": "evidence_validator",
        "summary": "Validate that compliance evidence artifacts exist and are properly formatted",
        "description": "Validate that compliance evidence artifacts exist, are properly formatted, and meet SOC 2 audit requirements.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["evidence_type", "cc_category", "content"],
                "properties": {
                  "evidence_type": {"type": "string"},
                  "cc_category": {"type": "string", "enum": ["CC6", "CC7", "CC8", "CC9"]},
                  "content": {"type": "object"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/git_commit_push": {
      "post": {
        "operationId": "git_commit_push",
        "summary": "Commit evidence artifacts to the compliance repository",
        "description": "Commit validated evidence artifacts to the compliance repository and push to remote. Used to create an immutable, timestamped audit trail. Only permitted to write to the evidence/ directory. Commit message must follow conventional commit format (e.g. 'feat(evidence): add CC6 scan results').",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["file_path", "content", "commit_message"],
                "properties": {
                  "file_path": {
                    "type": "string",
                    "description": "Path within the repository to write the evidence file. Must be under evidence/ directory."
                  },
                  "content": {
                    "type": "string",
                    "description": "Content of the evidence file to commit."
                  },
                  "commit_message": {
                    "type": "string",
                    "description": "Conventional commit message. Format: 'type(scope): description'. Example: 'feat(evidence): add CC6 scan results for 2026-02-22'."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Commit result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "committed": {"type": "boolean"},
                    "commit_sha": {"type": "string"},
                    "timestamp": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/sanitize_output": {
      "post": {
        "operationId": "sanitize_output",
        "summary": "Sanitize text output by redacting secrets, PII, and sensitive identifiers",
        "description": "Redact sensitive information from text before returning it to the user. AIUC-1 controls A004 and A006.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {"type": "string", "description": "The text content to sanitize."}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sanitized text",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/log_security_event": {
      "post": {
        "operationId": "log_security_event",
        "summary": "Log a security-relevant event to Application Insights",
        "description": "Log a security-relevant event to Azure Application Insights for audit trail. AIUC-1 control E015.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["event_type", "severity", "agent_id", "description"],
                "properties": {
                  "event_type": {
                    "type": "string",
                    "enum": ["prompt_injection_attempt", "scope_violation", "tool_call_rejected", "pii_redacted", "compliance_finding", "access_denied", "policy_violation", "audit_log"]
                  },
                  "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
                  "agent_id": {"type": "string"},
                  "description": {"type": "string"},
                  "metadata": {"type": "object"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event logged",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    }
  }
}
