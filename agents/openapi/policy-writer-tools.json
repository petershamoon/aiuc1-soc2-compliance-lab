{
  "openapi": "3.0.0",
  "info": {
    "title": "AIUC-1 Policy Writer Tools",
    "description": "Azure Functions providing compliance data retrieval capabilities for the policy-writer agent.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://aiuc1-soc2-tools.azurewebsites.net/api",
      "description": "AIUC-1 Azure Function App"
    }
  ],
  "paths": {
    "/scan_cc_criteria": {
      "post": {
        "operationId": "scan_cc_criteria",
        "summary": "Scan Azure resources against a SOC 2 Common Criteria control",
        "description": "REQUIRED before generating any policy. Scan Azure resources against a specific SOC 2 CC control to retrieve current compliance findings that the policy must address. Supported categories: CC6, CC7, CC8, CC9.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cc_category"],
                "properties": {
                  "cc_category": {"type": "string", "enum": ["CC6", "CC7", "CC8", "CC9"]},
                  "resource_group": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Compliance scan results",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/query_policy_compliance": {
      "post": {
        "operationId": "query_policy_compliance",
        "summary": "Query Azure Policy compliance state",
        "description": "Query Azure Policy compliance state for the subscription. Returns compliant and non-compliant resource counts and policy assignment details. Use this to ground policy documents in real compliance data.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resource_group": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Policy compliance state",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/query_access_controls": {
      "post": {
        "operationId": "query_access_controls",
        "summary": "Query Azure RBAC role assignments",
        "description": "Query Azure RBAC to retrieve all role assignments in scope. Use this to ground access control policies in real RBAC data.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resource_group": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "RBAC role assignments",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/sanitize_output": {
      "post": {
        "operationId": "sanitize_output",
        "summary": "Sanitize text output by redacting secrets, PII, and sensitive identifiers",
        "description": "Redact sensitive information from generated policy documents before returning them to the user. AIUC-1 controls A004 and A006.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sanitized text",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    },
    "/log_security_event": {
      "post": {
        "operationId": "log_security_event",
        "summary": "Log a security-relevant event to Application Insights",
        "description": "Log a security-relevant event to Azure Application Insights for audit trail. AIUC-1 control E015.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["event_type", "severity", "agent_id", "description"],
                "properties": {
                  "event_type": {
                    "type": "string",
                    "enum": ["prompt_injection_attempt", "scope_violation", "tool_call_rejected", "pii_redacted", "compliance_finding", "access_denied", "policy_violation", "audit_log"]
                  },
                  "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
                  "agent_id": {"type": "string"},
                  "description": {"type": "string"},
                  "metadata": {"type": "object"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Event logged",
            "content": {
              "application/json": {"schema": {"type": "object"}}
            }
          }
        }
      }
    }
  }
}
