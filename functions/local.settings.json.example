    "AZURE_SUBSCRIPTION_ID": "your-azure-subscription-id",
    "AZURE_FOUNDRY_ENDPOINT": "https://your-hub-name.services.ai.azure.com/",
    "AZURE_FOUNDRY_API_KEY": "your-foundry-api-key",
    "OPENAI_API_KEY": "your-openai-api-key",
    "SQL_ADMIN_PASSWORD": "your-sql-admin-password",
    "RESOURCE_GROUP_FOUNDRY": "rg-aiuc1-foundry",
    "RESOURCE_GROUP_PRODUCTION": "rg-production",
    "RESOURCE_GROUP_DEVELOPMENT": "rg-development",
    "FOUNDRY_HUB_NAME": "your-foundry-hub-name",
    "FOUNDRY_PROJECT_NAME": "your-foundry-project-name",
    "APPINSIGHTS_CONNECTION_STRING": "your-app-insights-connection-string",
    "GIT_REPO_PATH": "/path/to/your/local/repo",
    "TERRAFORM_WORKING_DIR": "/path/to/terraform",
    "TERRAFORM_APPROVAL_SECRET": "your-random-secret-for-hmac-signing"
  }
