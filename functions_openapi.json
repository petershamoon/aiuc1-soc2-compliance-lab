{
  "openapi": "3.0.0",
  "info": {
    "title": "AIUC-1 SOC 2 GRC Tools",
    "version": "1.0.0",
    "description": "A set of 12 Azure Functions for SOC 2 compliance auditing, designed to be called by an AI agent."
  },
  "paths": {
    "/api/gap_analyzer": {
      "post": {
        "operationId": "gap_analyzer",
        "summary": "Analyzes compliance gaps for a specific SOC 2 CC category (CC5, CC6, CC7) in a given resource group.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cc_category": {
                    "type": "string",
                    "description": "The SOC 2 Common Criteria category to analyze (e.g., CC5, CC6, CC7)."
                  },
                  "resource_group": {
                    "type": "string",
                    "description": "The target Azure resource group to scan."
                  }
                },
                "required": [
                  "cc_category",
                  "resource_group"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/scan_cc_criteria": {
      "post": {
        "operationId": "scan_cc_criteria",
        "summary": "Scans all resources of a specific type (e.g., Microsoft.Storage/storageAccounts) within a resource group.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cc_category": {
                    "type": "string",
                    "description": "The SOC 2 CC category that maps to the resource type."
                  },
                  "resource_group": {
                    "type": "string",
                    "description": "The target Azure resource group."
                  }
                },
                "required": [
                  "cc_category",
                  "resource_group"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/evidence_validator": {
      "post": {
        "operationId": "evidence_validator",
        "summary": "Validates if a specific Azure resource configuration meets a SOC 2 requirement.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resource_id": {
                    "type": "string",
                    "description": "The full Azure Resource ID of the resource to validate."
                  },
                  "expected_config": {
                    "type": "object",
                    "description": "A dictionary of expected configuration key-value pairs."
                  }
                },
                "required": [
                  "resource_id",
                  "expected_config"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/query_access_controls": {
      "post": {
        "operationId": "query_access_controls",
        "summary": "Queries the IAM role assignments for a specific Azure resource.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resource_id": {
                    "type": "string",
                    "description": "The full Azure Resource ID."
                  }
                },
                "required": [
                  "resource_id"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/query_defender_score": {
      "post": {
        "operationId": "query_defender_score",
        "summary": "Retrieves the Microsoft Defender for Cloud secure score for the subscription.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/query_policy_compliance": {
      "post": {
        "operationId": "query_policy_compliance",
        "summary": "Gets the Azure Policy compliance state for a specific resource group.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "resource_group": {
                    "type": "string",
                    "description": "The target Azure resource group."
                  }
                },
                "required": [
                  "resource_group"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/generate_poam_entry": {
      "post": {
        "operationId": "generate_poam_entry",
        "summary": "Generates a structured Plan of Action & Milestones (POA&M) entry for a compliance finding.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "weakness_description": {
                    "type": "string",
                    "description": "Detailed description of the compliance gap."
                  },
                  "affected_resource": {
                    "type": "string",
                    "description": "The name or ID of the affected resource."
                  },
                  "recommendation": {
                    "type": "string",
                    "description": "The recommended remediation action."
                  }
                },
                "required": [
                  "weakness_description",
                  "affected_resource",
                  "recommendation"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/run_terraform_plan": {
      "post": {
        "operationId": "run_terraform_plan",
        "summary": "Runs a `terraform plan` for a given remediation module to show the proposed changes.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "module_name": {
                    "type": "string",
                    "description": "The name of the Terraform remediation module to run."
                  }
                },
                "required": [
                  "module_name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/run_terraform_apply": {
      "post": {
        "operationId": "run_terraform_apply",
        "summary": "Runs a `terraform apply` to execute a remediation plan. Requires human approval.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "module_name": {
                    "type": "string",
                    "description": "The name of the Terraform remediation module to apply."
                  },
                  "human_approval_confirmation": {
                    "type": "string",
                    "description": "A confirmation string indicating human approval was given."
                  }
                },
                "required": [
                  "module_name",
                  "human_approval_confirmation"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/git_commit_push": {
      "post": {
        "operationId": "git_commit_push",
        "summary": "Commits and pushes changes (like a new POA&M) to the Git repository.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "commit_message": {
                    "type": "string",
                    "description": "The git commit message."
                  },
                  "file_path": {
                    "type": "string",
                    "description": "The path to the file to be committed."
                  }
                },
                "required": [
                  "commit_message",
                  "file_path"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/sanitize_output": {
      "post": {
        "operationId": "sanitize_output",
        "summary": "Scrubs sensitive information (like subscription IDs, keys, secrets) from text before displaying it.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text_to_sanitize": {
                    "type": "string",
                    "description": "The text content to be sanitized."
                  }
                },
                "required": [
                  "text_to_sanitize"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    },
    "/api/log_security_event": {
      "post": {
        "operationId": "log_security_event",
        "summary": "Logs a security-relevant event to the central logging system (Application Insights).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_name": {
                    "type": "string",
                    "description": "The name of the event (e.g., `HighRiskFinding`, `HumanApprovalGiven`)."
                  },
                  "event_details": {
                    "type": "object",
                    "description": "A dictionary of details about the event."
                  }
                },
                "required": [
                  "event_name",
                  "event_details"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyHeader": {
        "type": "apiKey",
        "name": "x-functions-key",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "apiKeyHeader": []
    }
  ]
}